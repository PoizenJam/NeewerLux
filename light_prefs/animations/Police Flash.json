{
  "name": "Police Flash",
  "description": "Alternating red/blue flash across lights",
  "loop": true,
  "keyframes": [
    {
      "hold_ms": 250,
      "fade_ms": 0,
      "lights": {
        "1": {"mode": "HSI", "hue": 0, "sat": 100, "bri": 100},
        "2": {"mode": "HSI", "hue": 240, "sat": 100, "bri": 100},
        "3": {"mode": "HSI", "hue": 0, "sat": 100, "bri": 100},
        "4": {"mode": "HSI", "hue": 240, "sat": 100, "bri": 100}
      }
    },
    {
      "hold_ms": 250,
      "fade_ms": 0,
      "lights": {
        "1": {"mode": "HSI", "hue": 240, "sat": 100, "bri": 100},
        "2": {"mode": "HSI", "hue": 0, "sat": 100, "bri": 100},
        "3": {"mode": "HSI", "hue": 240, "sat": 100, "bri": 100},
        "4": {"mode": "HSI", "hue": 0, "sat": 100, "bri": 100}
      }
    }
  ]
}
